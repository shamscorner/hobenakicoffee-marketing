---
import { LL } from '@utils/i18n';
import Layout from '@layouts/Layout.astro';
import FaqsComponent from '../components/faqs/faqs.svelte';
import type { FaqItem } from '@components/faqs/types';

const faqItems: FaqItem[] = Object.values(LL.pageFaqs.items).map((item) => {
	return {
		question: item.question(),
		answer: item.answer(),
	};
});
---

<Layout
	title={LL.pageFaqs.title()}
	description={LL.pageFaqs.description()}
	keywords={LL.pageFaqs.keywords()}
>
	<main
		class="grid min-h-screen place-items-center bg-gradient-to-b from-secondary/10 to-white px-6 py-24 sm:py-32 lg:px-8"
	>
		<section class="mx-auto w-full max-w-3xl">
			<h2 class="text-center text-3xl font-bold">{LL.pageFaqs.title()}</h2>
			<p class="mx-auto mb-10 mt-4 max-w-xl text-center text-lg">{LL.pageFaqs.description()}</p>

			<FaqsComponent client:load faqs={faqItems} />
		</section>
	</main>
</Layout>
