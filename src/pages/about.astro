---
import { LL } from '@utils/i18n';

import Layout from '@layouts/Layout.astro';
import { Heart } from 'lucide-astro';

export const prerender = 'true';
---

<Layout
	title={LL.pageAbout.title()}
	description={LL.pageAbout.description()}
	keywords={LL.pageAbout.keywords()}
>
	<main class="container mx-auto max-w-3xl px-4 py-12">
		<div class="flex flex-col gap-y-8">
			<div class="flex flex-col gap-y-2 text-center">
				<h1 class="text-3xl font-semibold tracking-tight">{LL.appName()}</h1>
				<p class="text-muted-foreground">বাংলাদেশি ক্রিয়েটরদের জন্য সাপোর্ট নেওয়ার প্ল্যাটফর্ম</p>
			</div>

			<div class="flex flex-col gap-y-6 pt-6">
				<div class="flex flex-col gap-y-4">
					<h2 class="text-2xl font-semibold">আমাদের গল্প</h2>
					<p class="text-muted-foreground leading-relaxed">
						{LL.description()}
					</p>
				</div>

				<div class="flex flex-col gap-y-4">
					<h2 class="text-2xl font-semibold">আমরা কারা</h2>
					<p class="text-muted-foreground leading-relaxed">
						{LL.appName()} এর পেছনে আছে একটি ছোট্ট টিম—যাদের লক্ষ্য একটাই: বাংলাদেশের ক্রিয়েটরদের কাজকে
						সাপোর্ট নেওয়া সহজ করা এবং সমর্থকদের সাথে অর্থপূর্ণ সম্পর্ক গড়ে তুলতে সাহায্য করা।
					</p>
				</div>

				<div class="flex flex-col gap-y-4">
					<h2 class="text-2xl font-semibold">আমাদের প্রতিশ্রুতি</h2>
					<p class="text-muted-foreground leading-relaxed">
						প্রতিটি কোড লাইন, প্রতিটি ফিচার, এবং প্রতিটি আপডেট আপনাদের প্রতি—আমাদের ব্যবহারকারীদের
						প্রতি আমাদের গভীর প্রতিশ্রুতি থেকে আসে। আমরা অসংখ্য রাত জেগেছি, অনেক চ্যালেঞ্জ
						পেরিয়েছি, এবং এই প্ল্যাটফর্ম তৈরি করতে আমাদের পুরো হৃদয় ঢেলে দিয়েছি। আপনাদের সাফল্যই
						আমাদের সাফল্য, এবং আমাদের প্ল্যাটফর্মের মাধ্যমে সৃষ্টিশীল মানুষদের উন্নতি দেখে আমরা
						গর্বিত।
					</p>
					<p class="text-muted-foreground leading-relaxed">
						আমরা বুঝি যে নিজের সৃষ্টিকে বিশ্বের সামনে তুলে ধরতে কতটা সাহস লাগে, এবং আপনার এই যাত্রার
						অংশ হতে পেরে আমরা সম্মানিত। আপনাদের মতামতই আমাদের পথ নির্ধারণ করে, এবং আপনাদের গল্পগুলোই
						আমাদের উন্নতির পথে এগিয়ে যাওয়ার প্রেরণা জোগায়।
					</p>
				</div>

				<div class="border-t pt-6">
					<p class="text-muted-foreground italic">{LL.pageContact.ourMoto()}</p>
					<div class="mt-4 flex items-center justify-end">
						<div class="flex items-center gap-2">
							<Heart class="text-primary h-4 w-4" />
							<p class="font-medium">{LL.appName()}</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>
