---
export interface Props {
	id?: string;
}

const { id } = Astro.props;

const noGtmScript = `
	<noscript>
		<iframe
			src="https://www.googletagmanager.com/ns.html?id=${id}"
			height="0"
			width="0"
			style="display:none;visibility:hidden"></iframe>
		</noscript>
	`;
---

{
	id && (
		<>
			<Fragment set:html={noGtmScript} />
		</>
	)
}
