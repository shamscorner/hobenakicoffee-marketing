---
import { LL } from '@utils/i18n';
import { Image } from 'astro:assets';

import HeroBanner from '@assets/people-joining-hands.jpg';
---

<section class="py-24">
	<!-- Hero Section -->
	<div class="flex flex-col items-center gap-10 md:flex-row">
		<div class="w-full md:w-1/3">
			<Image
				src={HeroBanner}
				alt="People joining hands altogether"
				title="This platform is build for creators, and they are not alone on their journey"
				class="bg-muted/20 mx-auto w-full max-w-[320px] rounded-2xl border p-2"
				loading="lazy"
			/>
		</div>
		<div class="w-full md:w-2/3">
			<h2 class="mb-4 text-3xl font-semibold tracking-tight md:text-4xl">
				{LL.landingPage.designedForCreators.title()}
			</h2>
			<p class="text-muted-foreground text-lg leading-relaxed">
				{LL.landingPage.designedForCreators.subTitle()}
			</p>
		</div>
	</div>

	<!-- Features Grid -->
	<ul class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
		{
			Object.values(LL.landingPage.designedForCreators.features).map((feature) => (
				<li class="bg-card flex flex-col gap-y-4 rounded-2xl border p-6">
					<div class="bg-primary/10 text-primary flex h-11 w-11 items-center justify-center rounded-xl">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							class="h-6 w-6"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							set:html={feature.icon()}
							aria-hidden="true"
						/>
					</div>
					<h3 class="text-lg font-semibold">{feature.title()}</h3>
					<p class="text-muted-foreground leading-relaxed">{feature.description()}</p>
				</li>
			))
		}
	</ul>
</section>
