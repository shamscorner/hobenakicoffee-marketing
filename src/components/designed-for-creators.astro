---
import { LL } from '@utils/i18n';
import { Image } from 'astro:assets';

import HeroBanner from '@assets/people-joining-hands.jpg';
---

<section class="py-24">
	<!-- Hero Section -->
	<div class="flex flex-col items-center gap-12 md:flex-row">
		<div class="w-full md:w-1/3">
			<Image
				src={HeroBanner}
				alt="People joining hands altogether"
				title="This platform is build for creators, and they are not alone on their journey"
				class="border-background mx-auto w-full max-w-[300px] rotate-3 rounded-2xl border-4 shadow-2xl transition-transform duration-500 hover:rotate-0"
				loading="lazy"
			/>
		</div>
		<div class="w-full md:w-2/3">
			<h2 class="text-primary mb-6 text-4xl font-extrabold tracking-tight md:text-5xl">
				{LL.landingPage.designedForCreators.title()}
			</h2>
			<p class="text-muted-foreground text-xl leading-relaxed">
				{LL.landingPage.designedForCreators.subTitle()}
			</p>
		</div>
	</div>

	<!-- Features Grid -->
	<ul class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
		{
			Object.values(LL.landingPage.designedForCreators.features).map((feature) => (
				<li class="group">
					<div class="bg-card border-primary/10 flex h-full flex-col gap-y-4 rounded-2xl border p-8 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
						<div class="bg-primary/10 h-12 w-12 rounded-lg p-2">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 24 24"
								class={`h-full w-full ${feature.color()}`}
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								set:html={feature.icon()}
								aria-hidden="true"
							/>
						</div>
						<h3 class="text-xl font-bold tracking-tight">{feature.title()}</h3>
						<p class="text-muted-foreground leading-relaxed">{feature.description()}</p>
					</div>
				</li>
			))
		}
	</ul>
</section>

)) }

