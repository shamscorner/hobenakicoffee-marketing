---
import {
	Heart,
	MessageCircle,
	Send,
	Home,
	Search,
	PlusSquare,
	PlaySquare,
	User,
	Camera,
	Ellipsis,
} from 'lucide-astro';
import SwirlyScribbledArrow from '@components/common/swirly-scribbled-arrow.astro';
import InstagramLogo from '@components/logos/instagram.astro';
---

<div class="flex w-full max-w-xs flex-col gap-y-4">
	<div class="flex items-center justify-center gap-3">
		<InstagramLogo class="w-12" />
		<span class="text-2xl font-semibold">Instagram</span>
	</div>
	<div class="relative mx-auto h-[600px] overflow-hidden rounded-2xl border">
		<!-- {/* Top Bar */} -->
		<div class="absolute left-0 right-0 top-0 z-10 flex items-center justify-between p-4">
			<div class="flex items-center gap-2">
				<span class="text-2xl font-semibold">Reels</span>
				<svg
					class="mt-2 h-3 w-3"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
				>
					<path d="M6 9l6 6 6-6"></path>
				</svg>
			</div>
			<Camera class="h-7 w-7" />
		</div>

		<!-- {/* Main Content */} -->
		<div class="relative flex h-full w-full items-start justify-center px-4">
			<div class="absolute left-1/2 top-20 h-16 w-16 rotate-180 text-primary">
				<SwirlyScribbledArrow />
			</div>
			<p
				class="mt-40 max-w-[18rem] rounded-md bg-gray-600/50 px-4 py-4 text-2xl font-bold text-white shadow-md"
			>
				hobenakicoffee.com<br />/abdur-rahman
			</p>
		</div>

		<!-- {/* User Info */} -->
		<div class="absolute bottom-20 left-4 right-16">
			<div class="flex items-center gap-2">
				<div class="h-7 w-7 shrink-0 rounded-full border-2 border-gray-200"></div>
				<span class="text-sm font-semibold">abdur-rahman</span>
				<div class="ml-1 rounded-md border border-white px-2 py-1 text-xs text-white">Follow</div>
			</div>
			<div class="mt-2 text-sm">ওয়েব ডেভেলপমেন্ট শেখার ১০ টি নিয়ম</div>
		</div>

		<!-- {/* Right Side Actions */} -->
		<div class="absolute bottom-24 right-4 flex flex-col items-center gap-6">
			<div class="flex flex-col items-center gap-1">
				<div>
					<Heart class="h-5 w-5" />
				</div>
				<span class="text-xs">44.6K</span>
			</div>
			<div class="flex flex-col items-center gap-1">
				<div>
					<MessageCircle class="h-5 w-5" />
				</div>
				<span class="text-xs">387</span>
			</div>
			<div class="flex flex-col items-center gap-1">
				<div>
					<Send class="h-5 w-5" />
				</div>
				<span class="text-xs">32.6K</span>
			</div>
			<div class="flex flex-col items-center gap-1">
				<div>
					<Ellipsis class="h-5 w-5" />
				</div>
			</div>
		</div>

		<!-- {/* Bottom Navigation */} -->
		<div
			class="absolute bottom-0 left-0 right-0 flex items-center justify-between border-t bg-gray-100 px-6 py-4"
		>
			<div class="flex flex-col items-center text-primary">
				<Home class="h-6 w-6" />
				<div class="mt-1 h-1 w-1 rounded-full bg-primary"></div>
			</div>
			<div class="flex flex-col items-center">
				<Search class="h-6 w-6" />
			</div>
			<div class="flex flex-col items-center">
				<PlusSquare class="h-6 w-6" />
			</div>
			<div class="flex flex-col items-center">
				<PlaySquare class="h-6 w-6" />
			</div>
			<div class="flex flex-col items-center">
				<User class="h-6 w-6" />
			</div>
		</div>
	</div>
</div>
