---
import * as Card from '$lib/components/ui/card/index.js';
import { CheckCircle, Download, MoreVertical, Share2, ThumbsDown, ThumbsUp } from 'lucide-astro';
import SwirlyScribbledArrow from '../common/swirly-scribbled-arrow.astro';
import { LL } from '@utils/i18n';
import SkeletonText from '@components/common/skeleton-text.astro';
import YoutubeLogo from '@components/logos/youtube.astro';
---

<div
	class="max-w-4xl rounded-xl border p-5"
	role="presentation"
	aria-labelledby="decorative-label-for-youtube-post"
>
	<YoutubeLogo class="-mt-10 w-12" />

	<div class="mb-4 mt-4">
		<SkeletonText class="h-4" />
		<SkeletonText class="h-4 max-w-60" />
	</div>

	<div class="mb-4 flex flex-col items-start justify-between gap-5 md:flex-row">
		<div class="flex items-center gap-3">
			<div class="h-10 w-10 rounded-full bg-gray-200"></div>
			<div class="text-sm">
				<div class="flex items-center gap-2">
					<div class="font-medium">আব্দুর রাহমান</div>
					<CheckCircle class="h-4 w-4 shrink-0 text-gray-500" />
				</div>
				<p class="text-sm text-gray-600">43K <span class="hidden sm:inline">subscribers</span></p>
			</div>
			<div
				class="ml-4 rounded-full bg-black px-2 py-2 text-xs font-medium text-white sm:px-4 sm:py-2 sm:text-sm"
			>
				Subscribe
			</div>
		</div>

		<div class="flex items-center gap-2 text-sm md:ml-auto">
			<div class="flex items-center rounded-full bg-gray-100">
				<div class="flex items-center rounded-l-full px-4 py-2">
					<ThumbsUp class="mr-2 h-4 w-4" />
					3.7K
				</div>
				<div class="h-6 w-px bg-gray-300"></div>
				<div class="flex items-center rounded-r-full px-4 py-2">
					<ThumbsDown class="h-4 w-4" />
				</div>
			</div>

			<div class="hidden rounded-full px-4 py-2 md:items-center md:gap-2 lg:flex">
				<Share2 class="h-4 w-4" />
				Share
			</div>

			<div class="flex items-center gap-2 rounded-full px-4 py-2">
				<Download class="h-4 w-4" />
				<span class="hidden md:inline">Download</span>
			</div>

			<div class="rounded-full p-2">
				<MoreVertical class="h-4 w-4" />
			</div>
		</div>
	</div>

	<Card.Root class="border-none bg-gray-100 p-4 shadow-none">
		<div class="mb-2 flex gap-2">
			<span>82,599 views</span>
			<span>Oct 23, 2024</span>
		</div>

		<div class="flex flex-col gap-y-4 text-sm">
			<SkeletonText class="mt-2 max-w-96" />

			<div>
				<SkeletonText count={2} />
			</div>

			<div>
				<SkeletonText class="max-w-64" />
				<div>
					<SkeletonText count={7} class="max-w-48" />
				</div>
			</div>

			<div class="relative flex flex-wrap items-center gap-2 py-2">
				ভিডিওটি ভালো লাগলে আমাকে কফি খাওয়াতে পারেন।
				<a
					href="https://hobenakicoffee.com/abdur-rahman"
					class="pointer-events-none flex gap-2 break-words text-blue-600 hover:underline"
				>
					https://hobenakicoffee.com/abdur-rahman
				</a>
				<div
					class="absolute left-[11rem] top-[-4rem] h-16 w-16 rotate-180 text-primary lg:-top-[4.8rem] lg:h-20 lg:w-20"
				>
					<SwirlyScribbledArrow />
				</div>
				<div
					id="decorative-label-for-youtube-post"
					class="absolute -top-32 left-[16rem] hidden max-w-[230px] text-xl font-semibold sm:block lg:left-[17rem] lg:text-2xl"
				>
					"{LL.landingPage.howItIsBeingUsed.youtube.hint()}"
				</div>
			</div>

			<div class="flex flex-wrap gap-2">
				<SkeletonText class="w-28" />
				<SkeletonText class="w-28" />
				<SkeletonText class="w-28" />
			</div>
		</div>
	</Card.Root>
</div>
