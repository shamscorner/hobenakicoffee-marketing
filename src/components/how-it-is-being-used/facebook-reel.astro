---
import {
	Search,
	Camera,
	UserCircle,
	ThumbsUp,
	MessageCircle,
	Share2,
	Bookmark,
	Home,
	Store,
	Bell,
	Menu,
} from 'lucide-astro';
import SwirlyScribbledArrow from '@components/common/swirly-scribbled-arrow.astro';
import FacebookLogo from '@components/logos/facebook.astro';
---

<div class="flex w-full max-w-xs flex-col gap-y-4">
	<div class="flex items-center justify-center gap-3">
		<FacebookLogo class="w-12" />
		<span class="text-2xl font-semibold">Facebook</span>
	</div>
	<div class="relative flex h-[600px] flex-col overflow-hidden rounded-2xl border">
		<!-- {/* Top Navigation */} -->
		<div
			class="absolute left-0 right-0 top-0 z-10 flex items-center justify-between bg-gray-100 p-2"
		>
			<div class="text-lg font-bold">Video</div>
			<div class="flex gap-3">
				<Search class="h-5 w-5" />
				<Camera class="h-5 w-5" />
				<UserCircle class="h-5 w-5" />
			</div>
		</div>

		<!-- {/* Main Video Content */} -->
		<div class="relative flex h-full w-full items-start justify-center px-4">
			<div class="absolute left-1/2 top-20 h-16 w-16 rotate-180 text-primary">
				<SwirlyScribbledArrow />
			</div>
			<p
				class="mt-40 max-w-[18rem] rounded-md bg-gray-600/50 px-4 py-4 text-2xl font-bold text-white shadow-md"
			>
				hobenakicoffee.com<br />/abdur-rahman
			</p>
		</div>

		<!-- {/* Right Side Interactions */} -->
		<div class="absolute bottom-16 right-1 flex flex-col items-center gap-3">
			<div class="flex flex-col items-center">
				<div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-200">
					<ThumbsUp class="h-5 w-5" />
				</div>
				<span class="text-xs">26.8K</span>
			</div>
			<div class="flex flex-col items-center">
				<div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-200">
					<MessageCircle class="h-5 w-5" />
				</div>
				<span class="text-xs">398</span>
			</div>
			<div class="flex flex-col items-center">
				<div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-200">
					<Share2 class="h-5 w-5" />
				</div>
				<span class="text-xs">293</span>
			</div>
			<div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-200">
				<Bookmark class="h-5 w-5" />
			</div>
		</div>

		<!-- {/* Bottom Content */} -->
		<div class="absolute bottom-16 left-4 right-12">
			<div class="flex items-center gap-2">
				<div class="h-8 w-8 rounded-full bg-muted"></div>
				<span class="text-sm font-semibold">Abdur Rahman</span>
			</div>
			<p class="mt-2 text-xs">ওয়েব ডেভেলপমেন্ট শেখার ১০ টি নিয়ম</p>
			<div class="no-scrollbar mt-2 flex items-center gap-2 overflow-x-auto">
				<div class="whitespace-nowrap rounded-full bg-white/10 px-2 py-1 text-[10px]">
					🎵 Abdur Rahman · Original audio
				</div>
			</div>
		</div>

		<!-- {/* Bottom Navigation */} -->
		<div
			class="absolute bottom-0 left-0 right-0 z-10 flex items-center justify-around border-t border-gray-300 bg-gray-100 px-1 py-1"
		>
			<div class="flex flex-col items-center gap-0.5 p-1">
				<Home class="h-5 w-5" />
				<span class="text-[8px]">Home</span>
			</div>
			<div class="flex flex-col items-center gap-0.5 p-1 text-blue-500">
				<div class="relative">
					<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
						<path d="M23 7l-7 5 7 5V7zm-7 10H1V7h15v10z"></path>
					</svg>
				</div>
				<span class="text-[8px]">Video</span>
			</div>
			<div class="relative flex flex-col items-center gap-0.5 p-1">
				<UserCircle class="h-5 w-5" />
				<span class="text-[8px]">Friends</span>
			</div>
			<div class="flex flex-col items-center gap-0.5 p-1">
				<Store class="h-5 w-5" />
				<span class="text-[8px]">Marketplace</span>
			</div>
			<div class="relative flex flex-col items-center gap-0.5 p-1">
				<Bell class="h-5 w-5" />
				<span class="text-[8px]">Notifications</span>
				<span
					class="absolute right-3 top-0.5 flex h-3 w-3 items-center justify-center rounded-full bg-red-500 text-[8px] text-white"
				>
					9
				</span>
			</div>
			<div class="flex flex-col items-center gap-0.5 p-1">
				<Menu class="h-5 w-5" />
				<span class="text-[8px]">Menu</span>
			</div>
		</div>
	</div>
</div>
