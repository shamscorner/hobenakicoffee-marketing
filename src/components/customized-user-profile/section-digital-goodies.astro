---
import { Gift } from 'lucide-astro';
---

<div class="bg-card flex h-full flex-col rounded-2xl border p-6 md:col-span-2 lg:col-span-3">
	<div class="mb-4 flex items-center">
		<Gift class="text-primary mr-2 h-5 w-5" />
		<h3 class="font-medium">ডিজিটাল গুডিজ</h3>
	</div>
	<p class="text-muted-foreground mb-4 text-sm leading-relaxed">
		স্টিকার, ওয়ালপেপার, সংগীত, এবং অন্যান্য ডিজিটাল কনটেন্ট ডাউনলোড করুন।
	</p>
	<div class="mb-4 grid grid-cols-2 gap-3">
		<div class="bg-muted/30 rounded-lg border p-2 text-center">
			<div class="bg-muted mb-1 h-10 w-full rounded"></div>
			<p class="text-xs">স্টিকার প্যাক</p>
		</div>
		<div class="bg-muted/30 rounded-lg border p-2 text-center">
			<div class="bg-muted mb-1 h-10 w-full rounded"></div>
			<p class="text-xs">ওয়ালপেপার</p>
		</div>
		<div class="bg-muted/30 rounded-lg border p-2 text-center">
			<div class="bg-muted mb-1 h-10 w-full rounded"></div>
			<p class="text-xs">সংগীত</p>
		</div>
		<div class="bg-muted/30 rounded-lg border p-2 text-center">
			<div class="bg-muted mb-1 h-10 w-full rounded"></div>
			<p class="text-xs">ডিজাইন</p>
		</div>
	</div>
	<div class="mt-auto">
		<div
			class="bg-primary/10 text-primary inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-semibold"
		>
			গুডিজ ব্রাউজ করুন
		</div>
	</div>
</div>
