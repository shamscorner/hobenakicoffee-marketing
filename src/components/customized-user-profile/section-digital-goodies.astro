---
import { Gift } from 'lucide-astro';
---

<div
	class="flex h-full flex-col rounded-xl border border-slate-100 bg-white p-6 md:col-span-2 lg:col-span-3"
>
	<div class="mb-4 flex items-center">
		<Gift class="mr-2 h-5 w-5 text-rose-500" />
		<h3 class="font-medium text-slate-800">ডিজিটাল গুডিজ</h3>
	</div>
	<p class="mb-4 text-sm text-slate-600">
		স্টিকার, ওয়ালপেপার, সংগীত, এবং অন্যান্য ডিজিটাল কনটেন্ট ডাউনলোড করুন।
	</p>
	<div class="mb-4 grid grid-cols-2 gap-3">
		<div class="rounded-md bg-rose-50 p-2 text-center">
			<div class="mb-1 h-10 w-full rounded bg-rose-100"></div>
			<p class="text-xs text-slate-700">স্টিকার প্যাক</p>
		</div>
		<div class="rounded-md bg-rose-50 p-2 text-center">
			<div class="mb-1 h-10 w-full rounded bg-rose-100"></div>
			<p class="text-xs text-slate-700">ওয়ালপেপার</p>
		</div>
		<div class="rounded-md bg-rose-50 p-2 text-center">
			<div class="mb-1 h-10 w-full rounded bg-rose-100"></div>
			<p class="text-xs text-slate-700">সংগীত</p>
		</div>
		<div class="rounded-md bg-rose-50 p-2 text-center">
			<div class="mb-1 h-10 w-full rounded bg-rose-100"></div>
			<p class="text-xs text-slate-700">ডিজাইন</p>
		</div>
	</div>
	<div class="mt-auto">
		<div
			class="inline-flex items-center justify-center rounded-md bg-rose-50 px-4 py-2 text-sm font-medium text-rose-700"
		>
			গুডিজ ব্রাউজ করুন
		</div>
	</div>
</div>
