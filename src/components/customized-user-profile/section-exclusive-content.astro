---
import { Lock, FileText, Music, Image as ImageIcon } from 'lucide-astro';
---

<div class="flex h-full flex-col rounded-xl border border-slate-100 bg-white p-6 md:col-span-2">
	<div class="mb-4 flex items-center">
		<Lock class="mr-2 h-5 w-5 text-purple-500" />
		<h3 class="font-medium text-slate-800">এক্সক্লুসিভ কন্টেন্ট</h3>
	</div>
	<p class="mb-4 text-sm text-slate-600">
		অন্য কোথাও পাওয়া যাবে না এমন প্রিমিয়াম কন্টেন্ট দেখার সুযোগ পান।
	</p>

	<div class="mb-8 flex flex-col gap-y-3">
		<div class="flex items-center">
			<div class="mr-2 flex h-8 w-8 items-center justify-center rounded-full bg-purple-100">
				<FileText class="h-4 w-4 text-purple-500" />
			</div>
			<div>
				<p class="text-sm font-medium text-slate-700">প্রিমিয়াম আর্টিকেল</p>
				<p class="text-xs text-slate-500">গভীর সৃজনশীল টিউটোরিয়াল</p>
			</div>
		</div>
		<div class="flex items-center">
			<div class="mr-2 flex h-8 w-8 items-center justify-center rounded-full bg-purple-100">
				<Music class="h-4 w-4 text-purple-500" />
			</div>
			<div>
				<p class="text-sm font-medium text-slate-700">কাস্টম রিংটোন</p>
				<p class="text-xs text-slate-500">অরিজিনাল অডিও সৃষ্টি</p>
			</div>
		</div>
		<div class="flex items-center">
			<div class="mr-2 flex h-8 w-8 items-center justify-center rounded-full bg-purple-100">
				<ImageIcon class="h-4 w-4 text-purple-500" />
			</div>
			<div>
				<p class="text-sm font-medium text-slate-700">এইচডি ওয়ালপেপার</p>
				<p class="text-xs text-slate-500">ডেস্কটপ এবং মোবাইলের জন্য</p>
			</div>
		</div>
	</div>

	<div class="mt-auto">
		<div
			class="inline-flex items-center justify-center rounded-md bg-purple-50 px-4 py-2 text-sm font-medium text-purple-700"
		>
			মেম্বারশিপে যোগ দিন
		</div>
	</div>
</div>
