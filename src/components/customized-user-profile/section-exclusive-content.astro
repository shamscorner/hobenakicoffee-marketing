---
import { Lock, FileText, Music, Image as ImageIcon } from 'lucide-astro';
---

<div class="bg-card flex h-full flex-col rounded-2xl border p-6 md:col-span-2">
	<div class="mb-4 flex items-center">
		<Lock class="text-primary mr-2 h-5 w-5" />
		<h3 class="font-medium">এক্সক্লুসিভ কন্টেন্ট</h3>
	</div>
	<p class="text-muted-foreground mb-4 text-sm leading-relaxed">
		অন্য কোথাও পাওয়া যাবে না এমন প্রিমিয়াম কন্টেন্ট দেখার সুযোগ পান।
	</p>

	<div class="mb-8 flex flex-col gap-y-3">
		<div class="flex items-center">
			<div
				class="bg-primary/10 text-primary mr-2 flex h-8 w-8 items-center justify-center rounded-full"
			>
				<FileText class="h-4 w-4" />
			</div>
			<div>
				<p class="text-sm font-medium">প্রিমিয়াম আর্টিকেল</p>
				<p class="text-muted-foreground text-xs">গভীর সৃজনশীল টিউটোরিয়াল</p>
			</div>
		</div>
		<div class="flex items-center">
			<div
				class="bg-primary/10 text-primary mr-2 flex h-8 w-8 items-center justify-center rounded-full"
			>
				<Music class="h-4 w-4" />
			</div>
			<div>
				<p class="text-sm font-medium">কাস্টম রিংটোন</p>
				<p class="text-muted-foreground text-xs">অরিজিনাল অডিও সৃষ্টি</p>
			</div>
		</div>
		<div class="flex items-center">
			<div
				class="bg-primary/10 text-primary mr-2 flex h-8 w-8 items-center justify-center rounded-full"
			>
				<ImageIcon class="h-4 w-4" />
			</div>
			<div>
				<p class="text-sm font-medium">এইচডি ওয়ালপেপার</p>
				<p class="text-muted-foreground text-xs">ডেস্কটপ এবং মোবাইলের জন্য</p>
			</div>
		</div>
	</div>

	<div class="mt-auto">
		<div
			class="bg-primary/10 text-primary inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-semibold"
		>
			মেম্বারশিপে যোগ দিন
		</div>
	</div>
</div>
