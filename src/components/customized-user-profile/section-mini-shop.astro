---
import { ShoppingBag } from 'lucide-astro';
---

<div class="bg-card flex h-full flex-col rounded-2xl border p-6 md:col-span-4">
	<div class="mb-4 flex items-center">
		<ShoppingBag class="text-primary mr-2 h-5 w-5" />
		<h3 class="font-medium">মিনি দোকান</h3>
	</div>
	<p class="text-muted-foreground mb-4 text-sm leading-relaxed">
		ক্রিয়েটরদের ডিজাইন করা পণ্য এবং মার্চেন্ডাইজ দেখুন এবং পছন্দ হলে কিনতে পারেন।
	</p>
	<div class="grid grid-cols-3 gap-2">
		<div class="bg-muted/30 rounded-xl border p-2 text-center">
			<div class="bg-muted mb-2 h-12 w-full rounded"></div>
			<p class="text-xs">ক্যাপ</p>
			<p class="text-primary text-xs font-semibold">৳২৫০</p>
		</div>
		<div class="bg-muted/30 rounded-xl border p-2 text-center">
			<div class="bg-muted mb-2 h-12 w-full rounded"></div>
			<p class="text-xs">আর্ট প্রিন্ট</p>
			<p class="text-primary text-xs font-semibold">৳১৫০</p>
		</div>
		<div class="bg-muted/30 rounded-xl border p-2 text-center">
			<div class="bg-muted mb-2 h-12 w-full rounded"></div>
			<p class="text-xs">মগ</p>
			<p class="text-primary text-xs font-semibold">৳১২০</p>
		</div>
	</div>
	<div class="mt-6">
		<div
			class="bg-primary/10 text-primary inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-semibold"
		>
			সব পণ্য দেখুন
		</div>
	</div>
</div>
