---
import { ShoppingBag } from 'lucide-astro';
---

<div class="flex h-full flex-col rounded-xl border border-slate-100 bg-white p-6 md:col-span-4">
	<div class="mb-4 flex items-center">
		<ShoppingBag class="mr-2 h-5 w-5 text-emerald-500" />
		<h3 class="font-medium text-slate-800">মিনি দোকান</h3>
	</div>
	<p class="mb-4 text-sm text-slate-600">
		ক্রিয়েটরদের ডিজাইন করা পণ্য এবং মার্চেন্ডাইজ দেখুন এবং পছন্দ হলে কিনতে পারেন।
	</p>
	<div class="grid grid-cols-3 gap-2">
		<div class="rounded-md bg-emerald-50 p-2 text-center">
			<div class="mb-2 h-12 w-full rounded bg-emerald-100"></div>
			<p class="text-xs text-slate-700">ক্যাপ</p>
			<p class="text-xs font-medium text-emerald-700">৳২৫০</p>
		</div>
		<div class="rounded-md bg-emerald-50 p-2 text-center">
			<div class="mb-2 h-12 w-full rounded bg-emerald-100"></div>
			<p class="text-xs text-slate-700">আর্ট প্রিন্ট</p>
			<p class="text-xs font-medium text-emerald-700">৳১৫০</p>
		</div>
		<div class="rounded-md bg-emerald-50 p-2 text-center">
			<div class="mb-2 h-12 w-full rounded bg-emerald-100"></div>
			<p class="text-xs text-slate-700">মগ</p>
			<p class="text-xs font-medium text-emerald-700">৳১২০</p>
		</div>
	</div>
	<div class="mt-6">
		<div
			class="inline-flex items-center justify-center rounded-md bg-emerald-50 px-4 py-2 text-sm font-medium text-emerald-700"
		>
			সব পণ্য দেখুন
		</div>
	</div>
</div>
