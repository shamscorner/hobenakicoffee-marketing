---
import { Film } from 'lucide-astro';
---

<div class="bg-card flex h-full flex-col rounded-2xl border p-6 md:col-span-2">
	<div class="mb-4 flex items-center">
		<Film class="text-primary mr-2 h-5 w-5" />
		<h3 class="font-medium">আমার কোর্সগুলো</h3>
	</div>
	<p class="text-muted-foreground mb-4 text-sm leading-relaxed">
		বিভিন্ন টিউটোরিয়াল, পর্দার পেছনের কাহিনী, এবং সৃজনশীল প্রক্রিয়া সম্পর্কিত ভিডিওগুলো দেখুন।
	</p>
	<div class="bg-muted/30 relative mb-3 h-32 w-full overflow-hidden rounded-xl border">
		<div class="absolute inset-0 flex items-center justify-center">
			<div class="bg-background flex h-10 w-10 items-center justify-center rounded-full border">
				<div
					class="border-l-primary ml-1 h-0 w-0 border-t-8 border-b-8 border-l-12 border-t-transparent border-b-transparent"
				>
				</div>
			</div>
		</div>
	</div>
	<p class="mb-1 text-xs font-semibold">সর্বশেষ: AI দিয়ে ওয়েব ডেভেলপমেন্ট</p>
	<p class="text-muted-foreground mb-4 text-xs">৩ দিন আগে প্রকাশিত • 55 মিনিট</p>
	<div class="mt-auto">
		<a
			class="bg-primary/10 text-primary inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-semibold"
		>
			কোর্সগুলো দেখুন
		</a>
	</div>
</div>
