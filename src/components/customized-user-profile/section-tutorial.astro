---
import { Film } from 'lucide-astro';
---

<div class="flex h-full flex-col rounded-xl border border-slate-100 bg-white p-6 md:col-span-2">
	<div class="mb-4 flex items-center">
		<Film class="mr-2 h-5 w-5 text-violet-500" />
		<h3 class="font-medium text-slate-800">আমার কোর্সগুলো</h3>
	</div>
	<p class="mb-4 text-sm text-slate-600">
		বিভিন্ন টিউটোরিয়াল, পর্দার পেছনের কাহিনী, এবং সৃজনশীল প্রক্রিয়া সম্পর্কিত ভিডিওগুলো দেখুন।
	</p>
	<div class="relative mb-3 h-32 w-full overflow-hidden rounded-md bg-violet-100">
		<div class="absolute inset-0 flex items-center justify-center">
			<div class="flex h-10 w-10 items-center justify-center rounded-full bg-white">
				<div
					class="border-l-12 ml-1 h-0 w-0 border-b-8 border-t-8 border-b-transparent border-l-violet-500 border-t-transparent"
				>
				</div>
			</div>
		</div>
	</div>
	<p class="mb-1 text-xs font-medium text-slate-700">সর্বশেষ: AI দিয়ে ওয়েব ডেভেলপমেন্ট</p>
	<p class="mb-4 text-xs text-slate-500">৩ দিন আগে প্রকাশিত • 55 মিনিট</p>
	<div class="mt-auto">
		<a
			class="inline-flex items-center justify-center rounded-md bg-violet-50 px-4 py-2 text-sm font-medium text-violet-700 transition-colors hover:bg-violet-100"
		>
			কোর্সগুলো দেখুন
		</a>
	</div>
</div>
