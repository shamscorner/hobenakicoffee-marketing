---
import { Heart } from 'lucide-astro';
---

<div
	class="flex h-full flex-col rounded-xl border border-slate-100 bg-white p-6 md:col-span-2 lg:col-span-3"
>
	<div class="mb-4 flex items-center">
		<Heart class="mr-2 h-5 w-5 text-pink-500" />
		<h3 class="font-medium text-slate-800">কমিউনিটি</h3>
	</div>
	<p class="mb-4 text-sm text-slate-600">
		সমর্থকদের একটি কমিউনিটিতে যোগ দিন এবং অন্যান্য সাপোর্টারদের সাথে যোগাযোগ করুন।
	</p>
	<div class="mb-3 flex -space-x-2">
		<div
			class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-blue-100"
		>
			<span class="text-xs font-medium text-blue-700">TK</span>
		</div>
		<div
			class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-green-100"
		>
			<span class="text-xs font-medium text-green-700">JM</span>
		</div>
		<div
			class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-amber-100"
		>
			<span class="text-xs font-medium text-amber-700">RS</span>
		</div>
		<div
			class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-purple-100"
		>
			<span class="text-xs font-medium text-purple-700">AL</span>
		</div>
		<div
			class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-slate-100"
		>
			<span class="text-xs font-medium text-slate-700">+৪২</span>
		</div>
	</div>
	<p class="mb-4 text-xs text-slate-500">আমাদের কমিউনিটিতে অন্য ২৪৬ জন সমর্থকের সাথে যোগ দিন</p>
	<div class="mt-auto">
		<div
			class="inline-flex items-center justify-center rounded-md bg-pink-50 px-4 py-2 text-sm font-medium text-pink-700"
		>
			কমিউনিটিতে যোগ দিন
		</div>
	</div>
</div>
