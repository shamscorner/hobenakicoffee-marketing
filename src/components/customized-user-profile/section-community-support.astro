---
import { Heart } from 'lucide-astro';
---

<div class="bg-card flex h-full flex-col rounded-2xl border p-6 md:col-span-2 lg:col-span-3">
	<div class="mb-4 flex items-center">
		<Heart class="text-primary mr-2 h-5 w-5" />
		<h3 class="font-medium">কমিউনিটি</h3>
	</div>
	<p class="text-muted-foreground mb-4 text-sm leading-relaxed">
		সমর্থকদের একটি কমিউনিটিতে যোগ দিন এবং অন্যান্য সাপোর্টারদের সাথে যোগাযোগ করুন।
	</p>
	<div class="mb-3 flex -space-x-2">
		<div
			class="bg-muted text-foreground border-background flex h-8 w-8 items-center justify-center rounded-full border-2"
		>
			<span class="text-xs font-semibold">TK</span>
		</div>
		<div
			class="bg-muted text-foreground border-background flex h-8 w-8 items-center justify-center rounded-full border-2"
		>
			<span class="text-xs font-semibold">JM</span>
		</div>
		<div
			class="bg-muted text-foreground border-background flex h-8 w-8 items-center justify-center rounded-full border-2"
		>
			<span class="text-xs font-semibold">RS</span>
		</div>
		<div
			class="bg-muted text-foreground border-background flex h-8 w-8 items-center justify-center rounded-full border-2"
		>
			<span class="text-xs font-semibold">AL</span>
		</div>
		<div
			class="bg-muted text-foreground border-background flex h-8 w-8 items-center justify-center rounded-full border-2"
		>
			<span class="text-xs font-semibold">+৪২</span>
		</div>
	</div>
	<p class="text-muted-foreground mb-4 text-xs">
		আমাদের কমিউনিটিতে অন্য ২৪৬ জন সমর্থকের সাথে যোগ দিন
	</p>
	<div class="mt-auto">
		<div
			class="bg-primary/10 text-primary inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-semibold"
		>
			কমিউনিটিতে যোগ দিন
		</div>
	</div>
</div>
