---
import { User } from 'lucide-astro';
---

<div class="bg-card flex h-full flex-col rounded-2xl border p-6 md:col-span-2 lg:col-span-3">
	<div class="mb-4 flex items-center">
		<User class="text-primary mr-2 h-5 w-5" />
		<h3 class="font-medium">আব্দুর রাহমান প্রসঙ্গে</h3>
	</div>
	<p class="text-muted-foreground text-sm leading-relaxed">
		আমি একজন ওয়েব ডেভেলপার ও অনলাইন শিক্ষক। সহজ ও পরিষ্কারভাবে ওয়েব ডেভেলপমেন্ট শেখাই—যাতে সবাই
		ধারাবাহিকভাবে দক্ষ হতে পারে। প্রযুক্তি ও নতুন আইডিয়া নিয়ে কাজ করতেই সবচেয়ে বেশি ভালো লাগে।
	</p>
	<div class="mt-10 flex items-center md:mt-auto">
		<div class="bg-primary/10 text-primary flex h-8 w-8 items-center justify-center rounded-full">
			<span class="text-xs font-semibold">AR</span>
		</div>
		<div class="ml-2">
			<p class="text-sm font-medium">আব্দুর রাহমান</p>
			<p class="text-muted-foreground text-xs">২০২৫ থেকে পথচলা</p>
		</div>
	</div>
</div>
