---
import { MessageCircle } from 'lucide-astro';
---

<div class="flex h-full flex-col rounded-xl border border-slate-100 bg-white p-6 md:col-span-2">
	<div class="mb-4 flex items-center">
		<MessageCircle class="mr-2 h-5 w-5 text-cyan-500" />
		<h3 class="font-medium text-slate-800">1-1 চ্যাট</h3>
	</div>
	<p class="mb-4 text-sm text-slate-600">
		ব্যক্তিগত পরামর্শ এবং মতামত পেতে একটি ভার্চুয়াল চ্যাট সেশন বুক করতে পারেন।
	</p>
	<div class="mb-8 rounded-lg bg-cyan-50 p-3">
		<p class="mb-1 text-xs font-medium text-cyan-800">পরবর্তী খালি সময়সূচি:</p>
		<div class="mt-3 grid grid-cols-2 gap-2">
			<div class="rounded bg-white p-1 text-xs text-cyan-700">মঙ্গলবার, সকাল ১০টা</div>
			<div class="rounded bg-white p-1 text-xs text-cyan-700">বুধবার, দুপুর ২টা</div>
			<div class="rounded bg-white p-1 text-xs text-cyan-700">বৃহস্পতিবার, সকাল ১১টা</div>
			<div class="rounded bg-white p-1 text-xs text-cyan-700">শুক্রবার, বিকেল ৪টা</div>
		</div>
	</div>
	<div class="mt-auto">
		<a
			class="inline-flex items-center justify-center rounded-md bg-cyan-50 px-4 py-2 text-sm font-medium text-cyan-700"
		>
			চ্যাট বুক করুন
		</a>
	</div>
</div>
