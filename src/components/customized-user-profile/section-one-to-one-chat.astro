---
import { MessageCircle } from 'lucide-astro';
---

<div class="bg-card flex h-full flex-col rounded-2xl border p-6 md:col-span-2">
	<div class="mb-4 flex items-center">
		<MessageCircle class="text-primary mr-2 h-5 w-5" />
		<h3 class="font-medium">১–১ চ্যাট</h3>
	</div>
	<p class="text-muted-foreground mb-4 text-sm leading-relaxed">
		ব্যক্তিগত পরামর্শ এবং মতামত পেতে একটি ভার্চুয়াল চ্যাট সেশন বুক করতে পারেন।
	</p>
	<div class="bg-muted/30 mb-8 rounded-xl border p-3">
		<p class="mb-1 text-xs font-semibold">পরবর্তী খালি সময়সূচি:</p>
		<div class="mt-3 grid grid-cols-2 gap-2">
			<div class="text-muted-foreground bg-background rounded border p-1 text-xs">
				মঙ্গলবার, সকাল ১০টা
			</div>
			<div class="text-muted-foreground bg-background rounded border p-1 text-xs">
				বুধবার, দুপুর ২টা
			</div>
			<div class="text-muted-foreground bg-background rounded border p-1 text-xs">
				বৃহস্পতিবার, সকাল ১১টা
			</div>
			<div class="text-muted-foreground bg-background rounded border p-1 text-xs">
				শুক্রবার, বিকেল ৪টা
			</div>
		</div>
	</div>
	<div class="mt-auto">
		<a
			class="bg-primary/10 text-primary inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-semibold"
		>
			চ্যাট বুক করুন
		</a>
	</div>
</div>
