---
import { LL } from '@utils/i18n';
import { Button } from '$lib/components/ui/button/index.js';
import * as Card from '$lib/components/ui/card/index.js';
import { cn } from '@utils/index';

const isUserAuthenticationEnabled = false;
---

<script is:inline type="module" async>
	let cards = document.querySelectorAll('.hero-card');
	let stackArea = document.getElementById('hero-stack-container');

	function rotateCards() {
		let angle = 0;
		cards.forEach((card, index) => {
			if (card.classList.contains('away')) {
				card.style.transform = `translateY(-120vh) rotate(-48deg)`;
			} else {
				card.style.transform = ` rotate(${angle}deg)`;
				angle = angle - 10;
				card.style.zIndex = cards.length - index;
			}
		});
	}

	rotateCards();

	window.addEventListener('scroll', () => {
		if (window.innerWidth < 768) return;
		if (!stackArea || !cards || !cards.length) return;

		let distance = window.innerHeight * 0.5;

		let topVal = stackArea.getBoundingClientRect().top;

		let index = -1 * (topVal / distance + 1);

		index = Math.floor(index);

		for (let i = 0; i < cards.length - 1; i++) {
			if (i <= index) {
				cards[i].classList.add('away');
			} else {
				cards[i].classList.remove('away');
			}
		}
		rotateCards();
	});
</script>

<div
	id="hero-stack-container"
	class="relative mx-auto flex flex-col gap-x-8 gap-y-16 pt-10 pb-16 md:h-[calc(300vh-3.5rem)] md:flex-row md:py-0"
>
	<div
		class="box-border flex flex-col justify-center gap-8 md:sticky md:top-[3.5rem] md:left-0 md:mt-0 md:h-[calc(100vh-3.5rem)] md:flex-1"
	>
		<div>
			<p
				class="text-muted-foreground bg-background/60 mb-5 inline-flex items-center rounded-full border px-3 py-1 text-sm font-semibold backdrop-blur"
			>
				{LL.landingPage.legend()}
			</p>

			<h1 class="max-w-4xl text-4xl leading-tight font-semibold tracking-tight sm:text-6xl">
				{LL.landingPage.title.part1()}<br />
				{LL.landingPage.title.part2()}<br />
				{LL.landingPage.title.part3()}
			</h1>
		</div>

		<p class="text-muted-foreground max-w-4xl text-lg leading-relaxed tracking-tight">
			{LL.landingPage.subtitle()}
		</p>

		<div>
			{
				isUserAuthenticationEnabled && (
					<Button href={import.meta.env.PUBLIC_SIGN_UP_PAGE_URL} size="xl" class="mr-4">
						{LL.landingPage.callToAction.getStarted()}
					</Button>
				)
			}
			<span class="text-muted-foreground text-sm">{LL.landingPage.callToAction.itsFree()}</span>
		</div>
	</div>
	<div class="sticky top-[3.5rem] hidden h-[calc(100vh-3.5rem)] flex-1 md:block">
		{
			Object.values(LL.landingPage.heroProps).map((heroItem) => (
				<Card.Root
					class={cn(
						'hero-card bg-card/80 absolute top-[calc(50%-175px)] left-[calc(50%-175px)] mb-10 h-[350px] w-[350px] rounded-2xl border p-5 shadow-xs backdrop-blur transition duration-500 ease-in-out',
						heroItem.extraClass()
					)}
				>
					<Card.Header>
						<Card.Title class="text-lg font-semibold">{heroItem.title()}</Card.Title>
					</Card.Header>
					<Card.Content class="flex h-full flex-col gap-4">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							class="h-14 w-14"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							set:html={heroItem.icon()}
							aria-hidden="true"
						/>
						<p class="text-muted-foreground mt-auto mb-14 text-2xl leading-normal font-medium">
							{heroItem.subtitle()}
						</p>
					</Card.Content>
					<Card.Footer />
				</Card.Root>
			))
		}
	</div>
	<div class="grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-8 md:hidden">
		{
			Object.values(LL.landingPage.heroProps).map((heroItem) => (
				<Card.Root
					class={cn('relative transition duration-500 ease-in-out', heroItem.extraClass())}
				>
					<Card.Header>
						<Card.Title class="text-lg font-semibold">{heroItem.title()}</Card.Title>
					</Card.Header>
					<Card.Content>
						<p class="text-muted-foreground mt-5 text-2xl leading-normal font-medium">
							{heroItem.subtitle()}
						</p>
					</Card.Content>
					<Card.Footer />
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						class="absolute top-4 right-4 h-12 w-12"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						set:html={heroItem.icon()}
						aria-hidden="true"
					/>
				</Card.Root>
			))
		}
	</div>
</div>

<style>
	.away {
		transform-origin: bottom left;
	}
</style>
